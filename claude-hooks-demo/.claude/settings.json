{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/typecheck.sh"
          },
          {
            "type": "command",
            "command": "cat >> /tmp/hook-debug-log.json"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/query_hook.js"
          }
        ]
      }
    ]
  }
}
